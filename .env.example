# Supabase 프로젝트 설정 (Project Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# 서버 전용(절대 클라이언트에 노출 금지) - 신청내역조회/수료증 발급 등 권한 상승 작업에 사용
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 사이트 기본 URL (OAuth 리다이렉트 등에 사용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 카카오 알림톡 연동(후속 구현 범위) - 설계 단계에서는 미사용, 값 미설정 시 발송 UI는 비활성 안내만 표시
KAKAO_BIZ_API_KEY=
KAKAO_SENDER_KEY=
