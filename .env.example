# Supabase 프로젝트 설정 (Project Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# GitHub Pages 프로젝트 사이트(https://<user>.github.io/<repo>/)는 서브패스에서 서빙되므로
# basePath가 필요하다. 로컬 개발(npm run dev)에서는 보통 비워둔다.
# 커스텀 도메인을 쓰는 경우에도 빈 문자열로 둔다.
NEXT_PUBLIC_BASE_PATH=

# 이 앱은 완전 정적(GitHub Pages) 배포이므로 서비스 롤 키를 Next 앱에서 직접 쓰지 않는다.
# 신청내역조회(성명+연락처 조회)처럼 RLS 우회가 필요한 로직만 Supabase Edge Function
# (supabase/functions/lookup)에서 처리하며, 해당 함수에는
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY가
# Supabase에 의해 자동으로 주입되므로 별도 설정이 필요 없다.
# (수료증 PDF 발급은 관리자 브라우저에서 직접 생성 — 별도 함수/키 불필요)

# 카카오 알림톡 연동(후속 구현 범위) - 설계 단계에서는 미사용
KAKAO_BIZ_API_KEY=
KAKAO_SENDER_KEY=
